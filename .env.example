# Case Intel Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Database Configuration (PostgreSQL with pgvector)
# ============================================================================
DB_NAME=CASE_INTEL
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# ============================================================================
# AI Provider Toggle
# ============================================================================
# Embedding provider: USE_GEMINI_EMBEDDINGS is checked first, then
# USE_OLLAMA (nomic-embed-text, 768-dim), then OpenAI as the final
# fallback. Whichever wins must be installed/reachable/keyed wherever this
# app runs, regardless of which LLM provider is used for chat generation
# below.
USE_OLLAMA=true

# Embedding provider: independent of USE_GROQ below. Set to "true" to route
# embeddings through Gemini's embed_content API instead of Ollama/OpenAI.
# You can have USE_GEMINI_EMBEDDINGS=true and USE_GROQ=true at the same
# time — that means Gemini for embeddings, Groq for generation.
USE_GEMINI_EMBEDDINGS=false

# LLM (chat generation) provider: independent of USE_OLLAMA above. Set to
# "true" to route generation through Groq instead of Ollama/OpenAI. You can
# have USE_GROQ=true and USE_OLLAMA=true at the same time — that means Groq
# for generation, Ollama for embeddings.
USE_GROQ=false

# ============================================================================
# Groq Configuration (used when USE_GROQ=true)
# ============================================================================
# Get a key at https://console.groq.com/keys
# NOTE: embeddings still require Ollama (or Gemini) running/keyed even when
# Groq handles generation — Groq is chat-only here, not an embedding
# provider.
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================================================
# Gemini Configuration (used when USE_GEMINI_EMBEDDINGS=true)
# ============================================================================
# Get a key at https://aistudio.google.com/apikey
# output_dimensionality is always forced to 768 in code (see
# GeminiEmbeddingService) to match DocumentChunk.embedding's fixed
# VectorField(768) column — do not expect this to scale with the model's
# native 3072-dim output.
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ============================================================================
# OpenAI Configuration (used when USE_OLLAMA=false, USE_GEMINI_EMBEDDINGS=false,
# and USE_GROQ=false)
# ============================================================================
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================================
# Ollama Configuration (used when USE_OLLAMA=true, for embeddings always and
# for chat generation when USE_GROQ=false)
# ============================================================================
# Ensure Ollama is running: ollama serve
# Pull required models:
#   ollama pull llama3.1:8b
#   ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ============================================================================
# AI Workflow Configuration
# ============================================================================
AI_SEARCH_TOP_K=10
AI_RERANK_TOP_K=5
AI_CONFIDENCE_THRESHOLD=0.5
AI_MAX_CONVERSATION_HISTORY=5

# ============================================================================
# Gmail OAuth Configuration
# ============================================================================
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REDIRECT_URI=http://localhost:8000/api/gmail/callback/

# ============================================================================
# File Storage (S3) Configuration
# ============================================================================
# USE_S3=false (the default) stores uploaded documents on local disk under
# media/, exactly as before -- no other setting below matters in that case.
# Set true to store uploads in S3 instead. The bucket must block all public
# access; files are reached only via short-lived presigned URLs (see
# AWS_S3_URL_EXPIRE_SECONDS), which the /api/documents/<id>/download/
# endpoint hands out behind the existing token auth.
USE_S3=false
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_URL_EXPIRE_SECONDS=3600

# ============================================================================
# Redis Configuration -- NOT CURRENTLY USED
# ============================================================================
# Celery has zero real task dispatch anywhere in this codebase (verified by
# grep for .delay(/.apply_async(/@shared_task -- none found) and the default
# cache backend is LocMemCache (see case_intel_project/settings.py), so
# neither CELERY_BROKER_URL/CELERY_RESULT_BACKEND nor REDIS_URL are read by
# settings.py anymore. Left commented out for reference in case Celery is
# ever actually wired up to a real task in the future.
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
# REDIS_URL=redis://127.0.0.1:6379/1
