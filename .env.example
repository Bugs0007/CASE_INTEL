# Case Intel Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Database Configuration (PostgreSQL with pgvector)
# ============================================================================
DB_NAME=CASE_INTEL
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# ============================================================================
# AI Provider Toggle
# ============================================================================
# Set to "true" to use local Ollama, "false" for OpenAI API
USE_OLLAMA=true

# ============================================================================
# OpenAI Configuration (used when USE_OLLAMA=false)
# ============================================================================
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================================
# Ollama Configuration (used when USE_OLLAMA=true)
# ============================================================================
# Ensure Ollama is running: ollama serve
# Pull required models:
#   ollama pull llama3.1:8b
#   ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ============================================================================
# AI Workflow Configuration
# ============================================================================
AI_SEARCH_TOP_K=10
AI_RERANK_TOP_K=5
AI_CONFIDENCE_THRESHOLD=0.5
AI_MAX_CONVERSATION_HISTORY=5

# ============================================================================
# Gmail OAuth Configuration
# ============================================================================
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REDIRECT_URI=http://localhost:8000/api/gmail/callback/

# ============================================================================
# Redis Configuration (Celery + Caching)
# ============================================================================
# Same Redis instance, different databases (0 for Celery, 1 for cache)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_URL=redis://127.0.0.1:6379/1
