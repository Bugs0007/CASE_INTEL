# Case Intel Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Database Configuration (PostgreSQL with pgvector)
# ============================================================================
DB_NAME=CASE_INTEL
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# ============================================================================
# AI Provider Toggle
# ============================================================================
# Set to "true" to use local Ollama, "false" for OpenAI API
USE_OLLAMA=true

# ============================================================================
# OpenAI Configuration (used when USE_OLLAMA=false)
# ============================================================================
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================================
# Ollama Configuration (used when USE_OLLAMA=true)
# ============================================================================
# Ensure Ollama is running: ollama serve
# Pull required models:
#   ollama pull llama3.1:8b
#   ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ============================================================================
# AI Workflow Configuration
# ============================================================================
AI_SEARCH_TOP_K=10
AI_RERANK_TOP_K=5
AI_CONFIDENCE_THRESHOLD=0.5
AI_MAX_CONVERSATION_HISTORY=5
