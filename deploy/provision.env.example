# Copy this file to deploy/provision.env and fill in values for the target
# box, then run: sudo ./deploy/provision.sh
#
# Every value here has a sane default matching this project's own production
# setup (see deploy/provision.sh) -- you only need to set what's different
# for a new box (e.g. a different domain for a different customer).

# Domain the Nginx site + eventual certbot cert should answer to.
DOMAIN=caseintel.duckdns.org

# Repo to clone. Fork this for a different customer's deployment.
GIT_REPO_URL=https://github.com/Bugs0007/CASE_INTEL.git
GIT_BRANCH=main

# Linux user the app runs as, and whose home directory the project is cloned
# into ($PROJECT_DIR defaults to ~<DEPLOY_USER>/CASE_INTEL). Must already
# exist on the box -- on a stock Ubuntu AMI on AWS this is "ubuntu".
DEPLOY_USER=ubuntu

# Uncomment to override the project directory instead of using
# ~<DEPLOY_USER>/CASE_INTEL:
# PROJECT_DIR=/home/ubuntu/CASE_INTEL

# systemd service name (also used for the sudoers restart rule and the Nginx
# site file name).
SERVICE_NAME=case-intel

# gunicorn bind address/port -- Nginx proxies to this.
GUNICORN_BIND=127.0.0.1:8000
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120

# Embedding model to pull via Ollama -- must match OLLAMA_EMBEDDING_MODEL in
# the app's own .env (see CLAUDE.md: embedding dimensions are hardcoded to
# 768 for nomic-embed-text, changing this needs a real migration).
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Swap file path/size.
SWAP_FILE=/swapfile
SWAP_SIZE_MB=1024
